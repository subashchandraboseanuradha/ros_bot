    <origin xyz="0.00289127586298088 0.0010656513836692378 0.012889229339118194" rpy="0 0 0"/>
    <mass value="0.006742869777511351"/>
    <inertia ixx="0.0" iyy="0.0" izz="0.0" ixy="-0.0" iyz="0.0" ixz="-0.0"/>
