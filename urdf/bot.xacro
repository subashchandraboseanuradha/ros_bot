<link name="lidar_link_1">
  <inertial>
    <origin xyz="-0.0006078599059984313 -0.00013002224629664804 0.014307180955488885" rpy="0 0 0"/>
    <mass value="0.053104251406073145"/>
    <inertia ixx="2.4e-05" iyy="2.4e-05" izz="4.4e-05" ixy="0.0" iyz="-0.0" ixz="-0.0"/>
