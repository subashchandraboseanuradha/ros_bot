    </geometry>
  </collision>
</link>

<link name="caster_wheel_b_1">
  <inertial>
    <origin xyz="0.01999999999999999 -2.634096614519092e-17 -0.012260416666666649" rpy="0 0 0"/>
    <mass value="0.01798247634914797"/>
    <inertia ixx="2e-06" iyy="2e-06" izz="2e-06" ixy="0.0" iyz="-0.0" ixz="-0.0"/>
