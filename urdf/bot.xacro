<?xml version="1.0" ?>
<robot name="bot" xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:include filename="$(find bot_description)/urdf/materials.xacro" />
<xacro:include filename="$(find bot_description)/urdf/bot.ros2control" />
<xacro:include filename="$(find bot_description)/urdf/bot.gazebo" />
<link name="base_link">
  <inertial>
    <origin xyz="0.0033109410397353595 -5.22133469861568e-05 0.07955691217854448" rpy="0 0 0"/>
    <mass value="2.042124391834186"/>
    <inertia ixx="0.022549" iyy="0.029976" izz="0.045754" ixy="1e-05" iyz="7e-06" ixz="-0.000498"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find bot_description)/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find bot_description)/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

